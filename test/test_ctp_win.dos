ctp::setLogLevel([INFO, INFO])

@testing:case="test_function_ctp_setLogLevel_pair",exception=1
ctp::setLogLevel(INFO:INFO)

@testing:case="test_function_ctp_setLogLevel_matrix",exception=1
ctp::setLogLevel(1..6$2:3)

@testing:case="test_function_ctp_setLogLevel_set",exception=1
ctp::setLogLevel(set(1 2 3))

@testing:case="test_function_ctp_setLogLevel_dict",exception=1
ctp::setLogLevel(dict(1 2 3, 1 2 3))

@testing:case="test_function_ctp_setLogLevel_table",exception=1
ctp::setLogLevel(table(1 2 3 as x))

@testing:case="test_function_ctp_getLogLevel_arg_over",syntaxError=1
ctp::getLogLevel(1)

@testing:case="test_ctp_getLogLevel_default"
assert 1, eqObj(ctp::getLogLevel(), getConfig("logLevel"))

@testing:case="test_function_ctp_getLogLevel_setLogLevel_multi_times"
for(logLevel in take([DEBUG, INFO, WARNING, ERROR], 1000)){
	ctp::setLogLevel(logLevel)
	ans = ctp::getLogLevel()
	if(logLevel==DEBUG){ex = "DEBUG"}
	if(logLevel==INFO){ex = "INFO"}
	if(logLevel==WARNING){ex = "WARNING"}
	if(logLevel==ERROR){ex = "ERROR"}
	assert 1, eqObj(ans, ex)
}

@testing:case="test_function_ctp_getLogLevel_setLogLevel_multi_jobs"
def submitJob_set(){
	for(logLevel in take([DEBUG, INFO, WARNING, ERROR], 1000)){
		ctp::setLogLevel(logLevel)
	}
}

def submitJob_get(){
	for(i in 1..1000){
		ans = ctp::getLogLevel()
		assert 1, ans in ["DEBUG", "INFO", "WARNING", "ERROR"]
	}
}

job1 = submitJob("submitJob_set", "submitJob_set", submitJob_set)
job2 = submitJob("submitJob_set", "submitJob_set", submitJob_set)
job3 = submitJob("submitJob_get", "submitJob_get", submitJob_get)
job4 = submitJob("submitJob_get", "submitJob_get", submitJob_get)
getJobReturn(job1, true)
getJobReturn(job2, true)
getJobReturn(job3, true)
getJobReturn(job4, true)
for(logLevel in take([DEBUG, INFO, WARNING, ERROR], 1000)){
	ctp::setLogLevel(logLevel)
	ans = ctp::getLogLevel()
	if(logLevel==DEBUG){ex = "DEBUG"}
	if(logLevel==INFO){ex = "INFO"}
	if(logLevel==WARNING){ex = "WARNING"}
	if(logLevel==ERROR){ex = "ERROR"}
	assert 1, eqObj(ans, ex)
}
