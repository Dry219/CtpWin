assert 4, size(ctp::getStatus(handle).subStatus) == 1

@testing:case="test_ctp_unsubscribe"//(√通过)
res = ctp::unsubscribe(handle, `marketData, ids[1:])
assert 1, res == `success
assert 2, size(ctp::getStatus(handle).ids) == 1
res = ctp::unsubscribe(handle, `marketData, ids[:1])
assert 3, res == `success
assert 4, size(ctp::getStatus(handle).ids) == 0

@testing:case="test_ctp_resubscribe"//(√通过)
res = ctp::subscribe(handle, `marketData,marketDataTable, ids);
assert 1, size(marketDataTable) > 0

@testing:case="test_ctp_getSchema_close"//(√通过)
res = ctp::close(handle);
assert 1, res == `success

@testing:case="test_ctp_persistence_table"//(√通过)
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, `marketData)
ctpTmpTable=streamTable(100:0, schema.name, schema.typeInt)
enableTableShareAndPersistence(table = ctpTmpTable, tableName=`ctp_market_data_sample, cacheSize = 100) 
go
ids = exec string(distinct_ids) from loadText(DATA_DIR+"/ids20260311.csv")
// ids = 'a2305' 'a2307' 'a2309' 'a2311' 'a2401' 'a2403' 'b2304' 'b2305' 'b2306' 'b2307' 'b2308' 'b2309' 'b2310' 'b2311' 'b2312' 'b2401'  'b2402' 'b2403' 'bb2304' 'bb2305' 'bb2306' 'bb2307' 'bb2308' 'bb2309' 'bb2310' 'bb2311' 'bb2312' 'bb2401' 'bb2402' 'bb2403' 'c2305' 'c2307' 'c2309' 'c2311' 'c2401' 'c2403' 'cs2305' 'cs2307' 'cs2309' 'cs2311' 'cs2401' 'cs2403' 'eb2304' 'eb2305' 'eb2306' 'eb2307' 'eb2308' 'eb2309' 'eb2310' 'eb2311' 'eb2312' 'eb2401' 'eb2402' 'eb2403' 'eg2304' 'eg2305' 'eg2306' 'eg2307' 'eg2308' 'eg2309' 'eg2310' 'eg2311' 'eg2312' 'eg2401' 'eg2402' 'eg2403' 'fb2304' 'fb2305' 'fb2306' 'fb2307' 'fb2308' 'fb2309' 'fb2310' 'fb2311' 'fb2312' 'fb2401' 'fb2402' 'fb2403' 'i2304' 'i2305' 'i2306' 'i2307' 'i2308' 'i2309' 'i2310' 'i2311' 'i2312' 'i2401' 'i2402' 'i2403' 'j2304' 'j2305' 'j2306' 'j2307' 'j2308' 'j2309' 'j2310' 'j2311' 'j2312' 'j2401' 'j2402' 'j2403' 'jd2304' 'jd2305' 'jd2306' 'jd2307' 'jd2308' 'jd2309' 'jd2310' 'jd2311' 'jd2312' 'jd2401' 'jd2402' 'jd2403' 'jm2304' 'jm2305' 'jm2306' 'jm2307' 'jm2308' 'jm2309' 'jm2310' 'jm2311' 'jm2312' 'jm2401' 'jm2402' 'jm2403' 'l2304' 'l2305' 'l2306' 'l2307' 'l2308' 'l2309' 'l2310' 'l2311' 'l2312' 'l2401' 'l2402' 'l2403' 'lh2305' 'lh2307' 'lh2309' 'lh2311' 'lh2401' 'lh2403' 'm2305' 'm2307' 'm2308' 'm2309' 'm2311' 'm2312' 'm2401' 'm2403' 'p2304' 'p2305' 'p2306' 'p2307' 'p2308' 'p2309' 'p2310' 'p2311' 'p2312' 'p2401' 'p2402' 'p2403' 'pg2304' 'pg2305' 'pg2306' 'pg2307' 'pg2308' 'pg2309' 'pg2310' 'pg2311' 'pg2312' 'pg2401' 'pg2402' 'pg2403' 'pp2304' 'pp2305' 'pp2306' 'pp2307' 'pp2308' 'pp2309' 'pp2310' 'pp2311' 'pp2312' 'pp2401' 'pp2402' 'pp2403' 'rr2304' 'rr2305' 'rr2306' 'rr2307' 'rr2308' 'rr2309' 'rr2310' 'rr2311' 'rr2312' 'rr2401' 'rr2402' 'rr2403' 'v2304' 'v2305' 'v2306' 'v2307' 'v2308' 'v2309' 'v2310' 'v2311' 'v2312' 'v2401' 'v2402' 'v2403' 'y2305' 'y2307' 'y2308' 'y2309' 'y2311' 'y2312' 'y2401' 'y2403''AP304' 'AP305' 'AP310' 'AP311' 'AP312' 'AP401' 'AP403' 'CF305' 'CF307' 'CF309' 'CF311' 'CF401' 'CF403' 'CJ305'