// subscribe exception handle （全部通过测试√）
@testing:case="test_ctp_subscribe_handle_int", exception=1
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, "marketData")
colNames = schema.schema().colDefs.name
colTypes = schema.schema().colDefs.typeInt
share streamTable(100:0, colNames, colTypes) as marketDataTable;
ids = `IF2603`IC2603`IH2603
ctp::subscribe(1, `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_handle_vector_int", exception=1
ctp::subscribe([1], `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_handle_vector_handle", exception=1
ctp::subscribe([handle,handle], `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_handle_void", exception=1
ctp::subscribe(NULL, `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_closed_handle", exception=1
ctp::close(handle);
ctp::subscribe(handle, `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_handle_vector_handle", exception=1
handle = ctp::connect(CtpIP, CtpPORT)
ctp::subscribe([handle], `marketData, marketDataTable, ids)

@testing:case="test_ctp_subscribe_handle_any_handle", exception=1
ctp::subscribe((handle,handle), `marketData, marketDataTable, ids)

