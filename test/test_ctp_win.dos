def wait_read_job_successful(jobId){
	for(i in 1..20){
		sleep(1000)
		end_time = (exec endTime from getJobStatus(jobId))[0]
		if(!isNull(end_time)){
			return getJobReturn(jobId)
		}
	}
	throw("Read Timeout!")
}

