// 这两个例子应该注释掉，不能测试，因为createIPCInMemoryTable这个功能没有。
@testing:case="test_ctp_getSchema_connect_ConcatTime_true_output_to_ipc_table"
try{ctp::close(handle);}catch(ex){}
try{dropIPCInMemoryTable("ipc_table_t");}catch(ex){} 

handle = ctp::connect(CtpIP, CtpPORT, dict(["ConcatTime"],[true]))
schema = ctp::getSchema(handle, `marketData)
ipc_table_t = createIPCInMemoryTable(1000000, "ipc_table_t", schema[`name], schema[`typeInt])
assert 1, handle == stringFormat("ctp handle of %W:%i",CtpIP, CtpPORT) 
ids = exec string(distinct_ids) from loadText(DATA_DIR+"/ids20230816.csv")
res = ctp::subscribe(handle, `marketData, ipc_table_t, ids);
sleep(5000)
assert 2, res == `success
assert 3, size(ctp::getStatus(handle).ids) == 18696
assert 4, size(ctp::getStatus(handle).subStatus) == 1
assert 5, time(ipc_table_t[`UpdateTime]) + time(ipc_table_t[`UpdateMillisec]) == time(ipc_table_t[`tradeTime])
job_id = submitJob("read_job","",get_IPC_table_data,"ipc_table_t")
re = wait_read_job_successful(job_id)
assert 6,re.size() > 0

@testing:case = "test_ctp_subscribe_output_to_ipc_table"
try{ctp::close(handle);}catch(ex){} 
try{dropIPCInMemoryTable("ipc_table_t");}catch(ex){} 

handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, `marketData)
ctpTmpTable=streamTable(100:0, schema.name, schema.typeInt)

ids = exec string(distinct_ids) from loadText(DATA_DIR+"/ids20230816.csv")
ipc_table_t = createIPCInMemoryTable(1000000, "ipc_table_t", schema[`name], schema[`typeInt])
ctp::subscribe(handle, "marketData", ipc_table_t, ids)

job_id = submitJob("read_job","",get_IPC_table_data,"ipc_table_t")
re = wait_read_job_successful(job_id)
assert 1,re.size() > 0

re = select * from ctp::getStatus(handle).subStatus where topicName  = "marketData"
assert 3,re.failedMsgCount[0] == 0
assert 4, ctp::getStatus(handle).ids.size() > 0
re = ctp::unsubscribe(handle, `marketData,ids)
assert 5, re=='success'
assert 6, ctp::getStatus(handle).ids.size() == 0
ctp::close(handle)
//----------------------------------------------------------------------------------------------
// 新增测试用例
// 数据正确性与完整性校验组 (Data Integrity Check)
// 检查核心接口返回的数据是否存在空值 (NULL) 或异常值
//----------------------------------------------------------------------------------------------
@testing:case="test_ctp_getSchema_data_check"
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, `marketData)
// 1. 确保获取到了 schema
assert 1, size(schema) > 0
// 2. 检查核心字段：列名、类型字符串、类型枚举不能出现空值 (NULL)
invalidCount = exec count(*) from schema where isNull(name) or isNull(typeString) or isNull(typeInt)
assert 2, invalidCount == 0
ctp::close(handle)

@testing:case="test_ctp_getStatus_data_check"
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, `marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
ids = exec string(distinct_ids) from loadText(DATA_DIR+"/ids20260311.csv")
ctp::subscribe(handle, `marketData, marketDataTable, ids)
// 等待几秒钟让后台处理订阅并生成状态
sleep(3000) 
status = ctp::getStatus(handle)
subStatusTable = status[`subStatus]
// 1. 确保 subStatus 表和 ids 列表不为空
assert 1, size(subStatusTable) > 0
assert 2, isNull(status[`ids]) == false
// 2. 检查 subStatus 表里的核心字段不能有空值
// 注意：lastErrMsg 和 lastFailedTimestamp 允许为空（如果没有发生过错误），但 topicName, startTime, processedMsgCount 必须有值
invalidCount = exec count(*) from subStatusTable where isNull(topicName) or isNull(startTime) or isNull(processedMsgCount)
assert 3, invalidCount == 0
ctp::close(handle)

@testing:case="test_ctp_subscribe_data_check"
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle, `marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
ids = exec string(distinct_ids) from loadText(DATA_DIR+"/ids20260311.csv")
sleep(1000)
ctp::subscribe(handle, `marketData, marketDataTable, ids)
// 等待 5 秒钟，让行情数据落入流表（注意：此用例必须在交易时间运行才会产生数据）
sleep(5000) 
// 1. 确保接收到了行情数据
assert 1, size(marketDataTable) > 0
// 2. 检查核心业务字段：合约ID、最新价、交易日、更新时间绝不允许有空值 (NULL)
invalidCount = exec count(*) from marketDataTable where isNull(InstrumentID) or isNull(LastPrice) or isNull(ActionDay) or isNull(UpdateTime)
assert 2, invalidCount == 0
// 3. 检查数值异常：最新价不能是极大异常值（CTP在未开盘时经常推 1.797693E308），也不能为负数
// 取决于测试环境，如果 SimNow 刚开盘有些无报价合约推极大值，可以根据业务需求适度放宽
abnormalCount = exec count(*) from marketDataTable where LastPrice >= 1.797693E308 or LastPrice < 0
assert 3, abnormalCount == 0
ctp::close(handle)


@testing:case="test_ctp_queryInstrument_data_check"
// 使用 TD 交易账号的参数进行查询
resTable = ctp::queryInstrument(queryInstrumentIp, queryInstrumentPort, qUserID, qPassword, qBrokerID, qAppID, qAuthCode)
// 1. 确保成功查到了合约列表
assert 1, size(resTable) > 0
// 2. 检查核心字段：合约ID、交易所ID、合约乘数、最小变动价位 绝不允许出现空值 (NULL)
invalidCount = exec count(*) from resTable where isNull(InstrumentID) or isNull(ExchangeID) or isNull(VolumeMultiple) or isNull(PriceTick)
assert 2, invalidCount == 0
// 3. 检查数值异常：合约乘数和最小变动价位必须严格大于 0
abnormalCount = exec count(*) from resTable where VolumeMultiple <= 0 or PriceTick <= 0
assert 3, abnormalCount == 0