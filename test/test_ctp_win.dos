ctp::subscribe(handle,`marketData,ctpTmpTable, ids);
ex = select * from ctpTmpTable
res = select * from ctp_market_data_sample
sleep(1000)
assert 1, each(eqObj,ex.values(),res.values())

clearTablePersistence(ctp_market_data_sample);

@testing:case="test_ctp_subscribe_one_id"//(√通过)
ctp::close(handle);
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle,`marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
res = ctp::subscribe(handle,`marketData,marketDataTable, [`ZC306]);
sleep(5000)
assert 1, res == `success
// assert 2, size(marketDataTable) > 0
assert 3, size(ctp::getStatus(handle).ids) == 1
res = ctp::subscribe(handle,`marketData,marketDataTable, [`TA306]);
assert 4, res == `success
assert 5, size(ctp::getStatus(handle).ids) == 2
res = ctp::subscribe(handle,`marketData,marketDataTable, [`SF306]);
assert 6, res == `success
assert 7, size(ctp::getStatus(handle).ids) == 3

@testing:case="test_ctp_subscribe_other_id"//(√通过)
ctp::close(handle);
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle,`marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
res = ctp::subscribe(handle,`marketData,marketDataTable, [`PP2212]);
sleep(5000)
assert 1, res == `success
assert 2, size(marketDataTable) == 0
assert 3, size(ctp::getStatus(handle).ids) == 1

@testing:case="test_ctp_subscribe_data_check"//(√通过)
ctp::close(handle);
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle,`marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
res = ctp::subscribe(handle,`marketData,marketDataTable, [`a2307]);
sleep(5000)
numCols = exec name from schema where typeString = 'INT' or type = 'DOUBLE'
count = size(marketDataTable)
for(numCol in numCols){
	for(i in 0..(count-1)){
		assert 1,marketDataTable[numCol][i]<1.797693E308
	}
}

@testing:case="test_ctp_connect_multiple"//(√通过)
ctp::close(handle);

def mConnect(CtpIP, CtpPORT){
	handle = ctp::connect(CtpIP, CtpPORT)
}

jobs = []
for(i in 0..50){
	jobs.append!(submitJob("mc", "mc", mConnect, CtpIP, CtpPORT))
}
for(jb in jobs){
	getJobReturn(jb, true)
}

@testing:case="test_ctp_subscribe_multiple"//(√通过)
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle,`marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable

def msubscribe(handle, ids, marketDataTable){
	res = ctp::subscribe(handle,`marketData,marketDataTable, ids);
	assert 1, res == `success
}

jobs = []
for(i in 0..50){
	jobs.append!(submitJob("ms", "ms", msubscribe, handle, ids, marketDataTable))
}
for(jb in jobs){
	getJobReturn(jb, true)
}

@testing:case="test_ctp_unsubscribe_multiple"//(√通过)
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
schema = ctp::getSchema(handle,`marketData)
share streamTable(100:0, schema.name, schema.typeInt) as marketDataTable
sleep(3000)
def msubscribe(handle, ids, marketDataTable){
	sleep(rand(500,1)[0])
	ctp::subscribe(handle,`marketData,marketDataTable, ids);
	sleep(100)
	ctp::unsubscribe(handle,`marketData, ids);
}

jobs = []
for(i in 0..50){
	jobs.append!(submitJob("mus", "mus", msubscribe, handle, ids, marketDataTable))
}
for(jb in jobs){
	getJobReturn(jb, true)
}
ctp::close(handle)

@testing:case="test_ctp_close_multiple"//(√通过)
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)
def mclose(handle){
	try{ctp::close(handle)}catch(ex){}
}

jobs = []
for(i in 0..10){
	jobs.append!(submitJob("mcl", "mcl", mclose, handle))
}
for(jb in jobs){
	getJobReturn(jb, true)
}

@testing:case="test_ctp_getSchema_multiple"//(√通过)
try{ctp::close(handle);}catch(ex){} 
handle = ctp::connect(CtpIP, CtpPORT)

def mgetSchema(handle){
	return ctp::getSchema(handle,`marketData)
}
jobs = []
for(i in 0..50){
	jobs.append!(submitJob("mg", "mg", mgetSchema, handle))
}
res = []
for(jb in jobs){
	res.append!(getJobReturn(jb, true))
}
for(re in res){
	assert 1, size(re) == 24 //47 改 24
}

@testing:case="test_ctp_getSchema_connect_ConcatTime_true"//(√通过)
